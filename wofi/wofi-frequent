#!/bin/bash

CACHE_DIR="$HOME/.cache/wofi-stats"
mkdir -p "$CACHE_DIR"

TRACK_FILE="$CACHE_DIR/launches"
PINNED_FILE="$CACHE_DIR/pinned"

add_launch() {
    local app="$1"
    [[ -z "$app" ]] && return
    echo "$(date +%s)" >> "$CACHE_DIR/$app"
}

show_pinned_apps() {
    if [[ -f "$PINNED_FILE" ]]; then
        cat "$PINNED_FILE"
    fi
}

get_frequent_apps() {
    local threshold=5
    local now=$(date +%s)
    local week_ago=$((now - 604800))

    for app_file in "$CACHE_DIR"/*; do
        [[ -f "$app_file" && "$app_file" != "$TRACK_FILE" && "$app_file" != "$PINNED_FILE" ]] || continue
        app_name=$(basename "$app_file")
        count=$(wc -l < "$app_file")
        if [[ $count -ge $threshold ]]; then
            echo "$count:$app_name"
        fi
    done | sort -t: -k1 -rn | head -6 | cut -d: -f2
}

if [[ "$1" == "--track" ]]; then
    add_launch "$2"
    exit 0
fi

wofi --show drun
